# ========================================
# Cloud Sidowski - Environment Configuration
# ========================================

# --- App Settings ---
APP_NAME="Datei Wolke"
BASE_URL="http://localhost:8080"
DEBUG_MODE=false
TWOFACTOR_DEBUG=false

# --- Database Settings ---
DB_SERVER="db"
DB_USERNAME="wolke_user"
DB_PASSWORD="wolke_password"
DB_NAME="datei_wolke"

# Database Root Password (required for Docker initialization)
MYSQL_ROOT_PASSWORD="root_fallback_password"

# --- File Management ---
# Maximum file upload size in Bytes (default: 104857600 = 100MB)
MAX_FILE_SIZE=104857600
# User Upload Directory path (default: user_uploads)
USER_UPLOAD_DIR="user_uploads"
# Allowed file extensions (comma separated)
ALLOWED_FILE_TYPES="pdf,doc,docx,xls,xlsx,ppt,pptx,odt,ods,odp,txt,rtf,csv,jpg,jpeg,png,gif,bmp,svg,webp,ico,mp3,wav,ogg,m4a,mp4,mov,avi,wmv,mkv,webm,zip,rar,7z,tar,gz"

# --- Contact & Imprint ---
CONTACT_PHONE="+49 123 456789"
CONTACT_EMAIL="support@sidowski.de"

# --- SMTP Settings (Emails) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="user@example.com"
SMTP_PASS="secret"
SMTP_FROM="noreply@example.com"
SMTP_NAME="Datei Wolke System"
SMTP_SECURE="tls"
