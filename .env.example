# Example .env for Datei Wolke
DB_SERVER=db_host_here
DB_USERNAME=db_username_here
DB_PASSWORD=db_password_here
DB_NAME=db_name_here
BASE_URL=https://yourdomain.tld

# SMTP
SMTP_HOST=smtp.yourdomain.tld
SMTP_USER=smtp_user_here
SMTP_PASS=smtp_password_here
SMTP_FROM=no-reply@yourdomain.tld
SMTP_NAME=No-Reply "Your App Name"
SMTP_PORT=465
SMTP_SECURE=ssl

# Debug flags
DEBUG_MODE=false
TWOFACTOR_DEBUG=false
